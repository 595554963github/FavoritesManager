<Window x:Class="FavoritesManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="收藏夹管理器" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <FontFamily x:Key="GlobalFont">Segoe UI, Microsoft YaHei</FontFamily>

        <DropShadowEffect x:Key="CardShadow" 
                          BlurRadius="12" 
                          ShadowDepth="2" 
                          Opacity="0.12" 
                          Color="#000000"/>

        <DropShadowEffect x:Key="ButtonShadow" 
                          BlurRadius="6" 
                          ShadowDepth="2" 
                          Opacity="0.25" 
                          Color="#000000"/>

        <Style x:Key="ListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="6,3"/>
            <Setter Property="Background" Value="LightBlue"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="{Binding Description}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F3E5F5"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.2" Color="#9C27B0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E8EAF6"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F51B5"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#4EC9B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MaxWidth" Value="350"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" 
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter x:Name="contentPresenter" 
                                                                  Margin="10,0,25,0"
                                                                  VerticalAlignment="Center"/>
                                                <Path x:Name="arrow" 
                                                      Fill="#666"
                                                      HorizontalAlignment="Right"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" 
                                        Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        Effect="{StaticResource CardShadow}">
                                    <ScrollViewer>
                                        <ItemsPresenter x:Name="ItemsPresenter"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="12,10" Margin="0,0,0,12" Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cmbCategory" Width="130" Style="{StaticResource ModernComboBox}"
                          SelectionChanged="cmbCategory_SelectionChanged">
                    <ComboBox.ToolTip>
                        <ToolTip Content="选择资源分类进行筛选" Style="{StaticResource CustomToolTipStyle}"/>
                    </ComboBox.ToolTip>
                </ComboBox>

                <TextBlock Text="搜索" VerticalAlignment="Center" Margin="25,0,8,0" 
                           FontFamily="{StaticResource GlobalFont}" FontWeight="SemiBold" Foreground="#555"/>

                <TextBox x:Name="txtSearch" Width="220" Style="{StaticResource SearchTextBox}"
                         TextChanged="txtSearch_TextChanged">
                    <TextBox.ToolTip>
                        <ToolTip Content="输入资源名称、网址、描述或分类进行搜索" Style="{StaticResource CustomToolTipStyle}"/>
                    </TextBox.ToolTip>
                </TextBox>

                <Button x:Name="btnAdd" Content="添加资源" Margin="35,0,0,0" 
                        Background="#4CAF50" Foreground="White" Style="{StaticResource ModernButton}">
                    <Button.ToolTip>
                        <ToolTip Content="点击添加新的资源到收藏夹" Style="{StaticResource CustomToolTipStyle}"/>
                    </Button.ToolTip>
                </Button>

                <Button x:Name="btnAbout" Content="关于" Margin="15,0,0,0" 
                        Background="#9C27B0" Foreground="White" Style="{StaticResource ModernButton}">
                    <Button.ToolTip>
                        <ToolTip Content="关于收藏夹管理器" Style="{StaticResource CustomToolTipStyle}"/>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="8" Effect="{StaticResource CardShadow}">
                <ListBox x:Name="lstResources" SelectionChanged="lstResources_SelectionChanged"
                         ItemContainerStyle="{StaticResource ListItemStyle}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" FontFamily="{StaticResource GlobalFont}"/>
                                <TextBlock Text="{Binding Url}" Foreground="#888" FontSize="11" 
                                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border Background="{Binding CategoryColor}" CornerRadius="12" 
                                            Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding CategoryDisplay}" FontSize="10" 
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="{Binding TypeColor}" CornerRadius="12" 
                                            Padding="8,3">
                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="10" 
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="4" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="2" Background="White" CornerRadius="10" 
                    Padding="18" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="资源详情" FontSize="18" FontWeight="Bold" 
                               FontFamily="{StaticResource GlobalFont}" 
                               Foreground="#2C3E50" Margin="0,0,0,18">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.1"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="名称" FontWeight="SemiBold" Foreground="#666" 
                               FontSize="12" Margin="0,5,0,3"/>
                    <TextBlock x:Name="txtDetailName" Text="-" Margin="0,0,0,12" 
                               FontFamily="{StaticResource GlobalFont}" FontSize="13"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="网址" FontWeight="SemiBold" Foreground="#666" 
                               FontSize="12" Margin="0,5,0,3"/>
                    <TextBlock x:Name="txtDetailUrl" Text="-" TextWrapping="Wrap" 
                               Margin="0,0,0,12" FontFamily="{StaticResource GlobalFont}" 
                               FontSize="12" Foreground="#2196F3" Cursor="Hand"
                               MouseLeftButtonDown="txtDetailUrl_MouseLeftButtonDown"/>

                    <TextBlock Text="分类" FontWeight="SemiBold" Foreground="#666" 
                               FontSize="12" Margin="0,5,0,3"/>
                    <TextBlock x:Name="txtDetailCategory" Text="-" Margin="0,0,0,12" 
                               FontFamily="{StaticResource GlobalFont}" FontSize="13"/>

                    <TextBlock Text="类型" FontWeight="SemiBold" Foreground="#666" 
                               FontSize="12" Margin="0,5,0,3"/>
                    <TextBlock x:Name="txtDetailType" Text="-" Margin="0,0,0,20" 
                               FontFamily="{StaticResource GlobalFont}" FontSize="13"/>

                    <Button x:Name="btnOpen" Content="打开网址" Click="btnOpen_Click" 
                            Background="#2196F3" Foreground="White" IsEnabled="False" 
                            Margin="0,0,0,12" Style="{StaticResource ModernButton}">
                        <Button.ToolTip>
                            <ToolTip Content="点击打开选中的资源网址" Style="{StaticResource CustomToolTipStyle}"/>
                        </Button.ToolTip>
                    </Button>

                    <Button x:Name="btnEdit" Content="编辑" Click="btnEdit_Click" 
                            Margin="0,0,0,10" Background="#FF9800" Foreground="White" 
                            Style="{StaticResource ModernButton}">
                        <Button.ToolTip>
                            <ToolTip Content="编辑选中的资源信息" Style="{StaticResource CustomToolTipStyle}"/>
                        </Button.ToolTip>
                    </Button>

                    <Button x:Name="btnDelete" Content="删除" Click="btnDelete_Click" 
                            Background="#F44336" Foreground="White" 
                            Style="{StaticResource ModernButton}">
                        <Button.ToolTip>
                            <ToolTip Content="删除选中的资源" Style="{StaticResource CustomToolTipStyle}"/>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12,8" Margin="0,12,0,0" Effect="{StaticResource CardShadow}">
            <Grid>
                <StatusBar Background="Transparent" BorderThickness="0">
                    <StatusBarItem>
                        <TextBlock x:Name="txtStatus" Text="就绪" FontFamily="{StaticResource GlobalFont}" Foreground="#555"/>
                    </StatusBarItem>
                    <StatusBarItem HorizontalAlignment="Right">
                        <TextBlock x:Name="txtCount" Text="共0个资源" FontFamily="{StaticResource GlobalFont}" Foreground="#888" FontWeight="SemiBold"/>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </Border>
    </Grid>
</Window>